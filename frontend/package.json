{
  "name": "gen-ai",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build",
    "ts-issues": "tsc --incremental",
    "format": "prettier . --write --list-different --cache --cache-strategy metadata"
  },
  "dependencies": {
    "marked": "^17.0.4",
    "preact": "^10.29.0",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "prettier": "^3.8.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.1"
  },
  "imports": {
    "#*": "./src/*"
  },
  "prettier": {
    "$schema": "http://json.schemastore.org/prettierrc",
    "trailingComma": "es5",
    "tabWidth": 2,
    "printWidth": 120,
    "semi": false,
    "singleQuote": true,
    "jsxSingleQuote": false,
    "bracketSameLine": true
  },
  "pnpm": {
    "ignoredBuiltDependencies": [
      "esbuild"
    ]
  }
}